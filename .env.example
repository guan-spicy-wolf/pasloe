# Pasloe Server Configuration
# Database Engine (Set to "sqlite" or "postgres")
DB_TYPE="postgres"

# SQLite settings (optional fallback)
SQLITE_PATH="./events.db"

# PostgreSQL settings (if DB_TYPE="postgres")
PG_USER="yoitsu"
PG_PASSWORD="yoitsu"
PG_HOST="127.0.0.1"
PG_PORT=5432
PG_DB="pasloe"

# Server settings
HOST="0.0.0.0"
PORT=8000
ENV="dev"
API_KEY="your-secret-api-key"
ALLOW_INSECURE_HTTP=false

# Webhooks
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF=1.0

# Pipeline workers
PIPELINE_POLL_INTERVAL_SECONDS=0.5
PIPELINE_BATCH_SIZE=64
PIPELINE_LEASE_SECONDS=30
PIPELINE_RETRY_BASE_SECONDS=1.0
PIPELINE_RETRY_MAX_SECONDS=60.0
HEALTH_MAX_OLDEST_UNCOMMITTED_AGE_SECONDS=60.0

# S3 Configuration for artifact uploads (Used manually by the clients via the /artifacts/presign endpoint)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="pasloe-artifacts"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"
